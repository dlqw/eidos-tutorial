Box[A] :: type {
    Wrap:: type(A)
}

Lift[F] :: type {
    Lift:: type(F[Int])
}

ApplyToInt[F: kind2] :: type {
    ApplyToInt:: type(F[Int])
}

UseK[K] :: type {
    UseK:: type(K[Box])
}

use_lift :: Lift[Box] -> Lift[Box]
{
    x => x
}

use_use_k :: UseK[ApplyToInt] -> UseK[ApplyToInt]
{
    x => x
}
