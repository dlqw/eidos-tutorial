
legacy_borrow_tag :: effect;

keep :: Int -> Int need legacy_borrow_tag
{
    x => x
}

keep_ref :: Ref[Int] -> Ref[Int]
{
    value => value
}

// Ownership is fixed by typed signatures: Int is ByValue and Ref[Int] is a
// SharedBorrow. Effect labels and legacy @borrow metadata cannot change either.
main :: Unit -> Int need legacy_borrow_tag
{
    _ => keep(1)
}
