// 55_ffi_basic.eidos — FFI 基础：声明和调用 C 函数

// @ffi 声明外部 C 函数，无函数体
// 编译器自动使用函数名作为 C 符号名
@ffi
puts :: RawPtr -> Int

// 显式指定 C 符号名（当 Eidos 名 != C 名时使用）
@ffi("malloc")
alloc :: Int -> RawPtr

main :: Int -> Int need FFI
{
    _ => {
        // 将 Eidos String 转为 C 字符串 (char*)
        msg := string_to_cstr("Hello from Eidos!");
        puts(msg);

        // 反向转换：C 字符串 → Eidos String
        // cstr_to_string(ptr) → String

        0
    }
}
